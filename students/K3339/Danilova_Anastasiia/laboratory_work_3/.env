DB_URL=postgresql://postgres:postgres@localhost:5432/time_manager_db
DB_URL_ASYNC=postgresql+asyncpg://postgres:postgres@localhost:5432/time_manager_db
SECRET_KEY=supersecretkey
ALGORITHM=HS256
CELERY_BROKER_URL=redis://localhost:6379/0
# Docker Compose maps Postgres to host port 5433 (see docker-compose.yml) so it does not clash with a local server on 5432.
